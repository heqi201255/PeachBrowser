{
  "server": {
    "port": 3000,
    "host": "0.0.0.0"
  },
  "database": {
    "path": "./data/peach.db"
  },
  "thumbnails": {
    "path": "./data/thumbnails",
    "videoTime": "00:00:03",
    "width": 320,
    "quality": 2
  },
  "scanner": {
    "skipFiles": [".DS_Store", "Thumbs.db", "desktop.ini"],
    "skipExtensions": [".tmp", ".temp"],
    "videoExtensions": [".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".mpeg", ".mpg", ".3gp", ".ts"],
    "imageExtensions": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp", ".tiff", ".tif", ".svg", ".ico"],
    "audioExtensions": [".mp3", ".wav", ".flac", ".aac", ".ogg", ".wma", ".m4a", ".ape"]
  },
  "pagination": {
    "defaultPageSize": 72,
    "maxPageSize": 200
  },
  "jwt": {
    "secret": "peach-browser-secret-key-change-in-production",
    "expiresIn": "7d"
  }
}
